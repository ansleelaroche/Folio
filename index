<!DOCTYPE html>
<html>
<head>
    <title>My Sleek Pantry</title>
    <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script> </head>
<body class="bg-stone-100 font-sans">
    <div id="root"></div>

    <script type="text/babel">
        const { useState } = React;

        function PantryApp() {
            // This is our "Chalkboard" (The State)
            const [items, setItems] = useState([
                { id: 1, name: "Organic Milk", qty: 1 },
                { id: 2, name: "Eggs", qty: 12 }
            ]);

            const addItem = () => {
                const newItem = { id: Date.now(), name: "New Item", qty: 1 };
                setItems([...items, newItem]); // This tells React: "Update your thoughts!"
            };

            return (
                <div class="max-w-md mx-auto p-6">
                    <h1 class="text-3xl font-light mb-8 text-stone-800">My Kitchen</h1>
                    
                    {/* The Inventory List */}
                    <div class="space-y-4">
                        {items.map(item => (
                            <div key={item.id} class="bg-white p-4 rounded-xl shadow-sm border border-stone-200 flex justify-between items-center">
                                <span class="text-lg text-stone-700">{item.name}</span>
                                <span class="bg-stone-100 px-3 py-1 rounded-full text-sm font-medium">{item.qty}</span>
                            </div>
                        ))}
                    </div>

                    {/* The "Quick Add" Button */}
                    <button 
                        onClick={addItem}
                        class="fixed bottom-8 right-8 bg-stone-800 text-white w-14 h-14 rounded-full shadow-lg text-2xl flex items-center justify-center hover:bg-stone-700 transition-all"
                    >
                        +
                    </button>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<PantryApp />);
    </script>
</body>
</html>
